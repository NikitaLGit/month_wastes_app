# Порт Express-сервера (nginx проксирует /wastes/ → localhost:PORT)
PORT=<port_here>

# Токен Telegram-бота — нужен для валидации initData и отправки уведомлений
BOT_TOKEN=<bot_token_here>

# Строка подключения к PostgreSQL (контейнер miniapp-db-1 в сети app_default)
DATABASE_URL=postgresql://user:password@dbname:5432/wastes
